{
  "name": "@NguyenDunga/dotnet-package-management",
  "version": "1.0.0",
  "description": "A simple fixing project management for dotnet project",
  "keywords": [
    "TypeScript"
  ],
  "homepage": "https://github.com/NguyenDunga/DPM#readme",
  "bugs": {
    "url": "https://github.com/NguyenDunga/DPM/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NguyenDunga/HRM.DPM.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "GPL-3.0-or-later",
  "author": "",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "dpm": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/cli.ts",
    "dev": "tsx watch src/cli.ts",
    "build": "tsup src/cli.ts --format esm --target node18 --clean --shims",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "fast-xml-parser": "^5.10.0",
    "tsup": "^8.5.1"
  }
}